{
  "name": "xkaliber-agent",
  "version": "23.0.0",
  "description": "Xkaliber Agent - A modern, dark-themed autonomous agent client for local Ollama models with Multimodal Vision, System Harness, Web Tools, WhatsApp Integration, and Persistent Memory.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "ollama",
    "chat",
    "electron",
    "tts",
    "piper",
    "netrunner",
    "agent",
    "memory",
    "parameters",
    "context",
    "attachments",
    "vision",
    "multimodal"
  ],
  "author": {
    "name": "System76",
    "email": "support@system76.com"
  },
  "homepage": "https://github.com/system76/xkaliber-agent",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "marked": "^11.1.1",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6"
  },
  "build": {
    "appId": "com.xkaliber.agent",
    "productName": "Xkaliber Agent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "executableName": "xkaliber-agent",
      "synopsis": "Xkaliber Agent with Multimodal Vision"
    },
    "extraResources": [
      {
        "from": "resources/piper",
        "to": "piper",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
